// ────────────── wluma: auto brightness from ambient light sensor ──────────────
spawn-at-startup "wluma"

// ────────────── iio-niri: auto screen rotation ──────────────
// Waits for accelerometer, then starts iio-niri. See scripts/iio-niri-wait.sh.
spawn-at-startup "sh" "-c" "$HOME/Projects/yoga-dotfiles/scripts/iio-niri-wait.sh"
