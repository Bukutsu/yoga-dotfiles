[Unit]
Description=iio-niri auto-rotation daemon
BindsTo=niri.service
After=niri.service
PartOf=graphical-session.target

[Service]
Type=simple
ExecStartPre=/usr/bin/gdbus wait --system --timeout 30 net.hadess.SensorProxy
ExecStart=/usr/bin/iio-niri listen --monitor eDP-1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
