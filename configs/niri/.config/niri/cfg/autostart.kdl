spawn-at-startup "noctalia"
spawn-sh-at-startup "i=0; while [ $i -lt 30 ]; do dbus-send --system --print-reply --dest=net.hadess.SensorProxy /net/hadess/SensorProxy org.freedesktop.DBus.Peer.Ping >/dev/null 2>&1 && exec iio-niri listen --monitor eDP-1; i=$((i+1)); sleep 1; done"
spawn-sh-at-startup "qs -c noctalia-shell"
